[global]
    monitor = 0
    follow = mouse

    width = 320
    height = 120
    origin = top-right
    offset = 16x40

    notification_limit = 5

    font = JetBrainsMono Nerd Font 10

    frame_width = 2
    frame_color = "#22e156"
    separator_color = frame

    padding = 12
    horizontal_padding = 12
    text_icon_padding = 0

    corner_radius = 0

    markup = full
    format = "<b>%s</b>\n%b"

    alignment = left
    vertical_alignment = center

    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false

    show_indicators = yes

    icon_position = off

    sticky_history = yes
    history_length = 20

    dmenu = /usr/bin/rofi -dmenu -p "> notifications"
    browser = /usr/bin/firefox -new-tab

    always_run_script = true

    title = Dunst
    class = Dunst

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#0f0f0f"
    foreground = "#f9f9f9"
    timeout = 4

[urgency_normal]
    background = "#0f0f0f"
    foreground = "#f9f9f9"
    timeout = 6

[urgency_critical]
    background = "#0f0f0f"
    foreground = "#f9f9f9"
    frame_color = "#e05d5d"
    timeout = 0
